# ====================================================================
# HEEMAH JEWELRY — ENVIRONMENT VARIABLES
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to git. It is already in .gitignore.
# ====================================================================

# --- Server ---
PORT=5000
NODE_ENV=production
# Comma-separated list of domains allowed to call this API
ALLOWED_ORIGINS=https://www.heemahjewelry.com,https://heemahjewelry.com

# --- Paystack ---
# Get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_bf03e286558ef6999a6f698ab0d55df2c24d2e3e
PAYSTACK_PUBLIC_KEY=pk_test_a8730cb41f4820e01b9c2cdfba097714667ee2ea

# --- Google Apps Script (sales logging to Google Sheets) ---
# Deploy the Apps Script in /google-apps-script/Code.gs as a Web App
# and paste the resulting /exec URL here.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec
# Shared secret the backend sends and Apps Script verifies, so random
# people can't post fake rows into your sheet.
GOOGLE_SCRIPT_SHARED_SECRET=replace-with-a-long-random-string

# --- Admin notification target ---
ADMIN_EMAIL=samueladeoye834@gmail.com

# --- Outgoing email (receipts) ---
# Any SMTP provider works (Gmail App Password, Zoho, SendGrid SMTP, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youraccount@gmail.com
SMTP_PASS=replace-with-app-password
EMAIL_FROM_NAME=Heemah Jewelry

# --- WhatsApp admin notifications ---
# Using Meta's WhatsApp Cloud API. If you don't have this set up yet,
# leave blank — the app degrades gracefully and just skips this step.
WHATSAPP_API_URL=https://graph.facebook.com/v20.0/REPLACE_PHONE_NUMBER_ID/messages
WHATSAPP_TOKEN=replace-with-permanent-access-token
WHATSAPP_ADMIN_NUMBER=2348132852928

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MINUTES=10
RATE_LIMIT_MAX_REQUESTS=100
